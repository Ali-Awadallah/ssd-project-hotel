<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="20" alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.UserManagementController"
      style="-fx-background-color: #ecf0f1; -fx-padding: 20;">

    <Label text="User Management" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <!-- Add User Form -->
    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
        <Label text="Add New User" style="-fx-font-weight: bold;"/>
        <HBox spacing="10">
            <TextField fx:id="username" promptText="Username" HBox.hgrow="ALWAYS"/>
            <PasswordField fx:id="password" promptText="Password" HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="role" promptText="Role"/>
        </HBox>
        <Button text="Add User" onAction="#addUser"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
    </VBox>

    <!-- Users Table -->
    <TableView fx:id="table" prefHeight="400">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colUsername" text="Username" prefWidth="150"/>
            <TableColumn fx:id="colRole" text="Role" prefWidth="100"/>
            <TableColumn fx:id="colFailedAttempts" text="Failed Attempts" prefWidth="100"/>
            <TableColumn fx:id="colLastLogin" text="Last Login" prefWidth="150"/>
            <TableColumn fx:id="colActive" text="Active" prefWidth="80"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="Reset Password" onAction="#resetPassword"
                style="-fx-background-color: #f39c12; -fx-text-fill: white;"/>
        <Button text="Toggle Active" onAction="#toggleActive"
                style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="Delete User" onAction="#deleteUser"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        <Button text="Refresh" onAction="#refresh"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
    </HBox>

</VBox>