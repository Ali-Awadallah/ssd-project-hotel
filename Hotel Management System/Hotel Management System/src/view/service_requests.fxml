<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="20" alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.ServiceRequestsController"
      style="-fx-background-color: #ecf0f1; -fx-padding: 20;">

    <Label text="Service Requests" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <!-- New Request Form -->
    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
        <Label text="Create New Request" style="-fx-font-weight: bold;"/>
        <TextField fx:id="reservationId" promptText="Reservation ID"/>
        <ComboBox fx:id="requestType" promptText="Request Type"/>
        <TextArea fx:id="description" promptText="Description" prefHeight="80"/>
        <Button text="Submit Request" onAction="#createRequest"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
    </VBox>

    <!-- Requests Table -->
    <TableView fx:id="table" prefHeight="400">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colReservationId" text="Reservation ID" prefWidth="100"/>
            <TableColumn fx:id="colType" text="Type" prefWidth="120"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="300"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
            <TableColumn fx:id="colCreatedAt" text="Created" prefWidth="150"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="Mark In Progress" onAction="#markInProgress"
                style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="Mark Completed" onAction="#markCompleted"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button text="Refresh" onAction="#refresh"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
    </HBox>

</VBox>