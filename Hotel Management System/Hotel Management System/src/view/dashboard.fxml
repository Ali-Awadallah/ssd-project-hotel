<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.DashboardController"
            style="-fx-background-color: #ecf0f1;">

    <!-- TOP MENU BAR -->
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <Label text="Hotel Management System"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout"
                    onAction="#logout"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR - ADDED fx:id="sidebar" -->
    <left>
        <VBox fx:id="sidebar"
              spacing="15"
              style="-fx-background-color: #34495e; -fx-padding: 20;"
              prefWidth="200">
            <!-- Sidebar buttons will be added dynamically in code -->
        </VBox>
    </left>

    <!-- MAIN CONTENT AREA -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color: #ecf0f1;">
            <Label text="Welcome to Dashboard"
                   style="-fx-font-size: 20px; -fx-alignment: center;"/>
        </StackPane>
    </center>

</BorderPane>