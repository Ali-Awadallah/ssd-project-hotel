<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PaymentController">

    <VBox spacing="15" alignment="CENTER"
          AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0">

        <padding>
            <Insets top="30"/>
        </padding>

        <Label text="Payment"
               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <!-- FORM CARD -->
        <VBox spacing="10"
              style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2),10,0,0,2);">

            <TextField fx:id="reservationId" promptText="Reservation ID"/>
            <TextField fx:id="amount" promptText="Amount"/>

            <Button text="Pay"
                    onAction="#pay"
                    style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 14px;"/>

        </VBox>

    </VBox>

</AnchorPane>